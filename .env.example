# Engram — Environment Variables
# Copy to .env and fill in your values.

# --- Neo4j ---
NEO4J_PASSWORD=changeme_strong_password

# --- mem0 API Server ---
ADMIN_API_KEY=changeme_api_key
# OPENAI_API_KEY is required by the mem0 base image even when using Ollama.
# Set to a dummy value if not using OpenAI.
OPENAI_API_KEY=unused-ollama-only

# --- PostgreSQL (pgvector) ---
POSTGRES_PASSWORD=changeme_pg_password

# --- Vault Sync ---
# Path to your Obsidian vault (or any markdown directory).
# This is mounted read-only into the vault-sync container.
VAULT_PATH=/path/to/your/vault
USER_ID=your_username

# --- Ollama (used in mem0-config.json, not directly by Docker) ---
# Base URL of your Ollama instance.
OLLAMA_BASE_URL=http://localhost:11434
